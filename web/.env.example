# ──────────────────────────────────────────────
# 김경수 디지털 상황실 — 환경 변수
# 이 파일을 .env로 복사 후 값을 채워서 사용하세요
# ──────────────────────────────────────────────

# [필수] Supabase 프로젝트 (REST API 연결)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# [필수] JWT 세션 서명 키 (임의의 문자열)
JWT_SECRET=your-secret-key-here

# [필수] 앱 식별자 (개발 환경에서는 아무 값이나 OK)
VITE_APP_ID=kim-kyungsu-dev

# [선택] OAuth (프로덕션 전용 — 개발 시에는 /api/dev/login 사용)
# OAUTH_SERVER_URL=https://your-oauth-server.com
# VITE_OAUTH_PORTAL_URL=https://your-oauth-portal.com

# [선택] 이 openId를 가진 유저를 자동으로 관리자로 승격
# OWNER_OPEN_ID=

# [선택] Manus 플랫폼 파일 저장소 (없으면 파일 업로드 비활성)
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=

# [선택] 최초 관리자 계정 생성 시 필요한 키 (기본값: kimkyungsu2026!)
# ADMIN_SETUP_KEY=kimkyungsu2026!

# [선택] Analytics (빈값이면 비활성)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# [선택] 서버 포트 (기본값: 3000)
PORT=3000
